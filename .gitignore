## Ignore Visual Studio temporary files, build results, and files generated by popular extensions.
 
# Build results
bin/
obj/
[Bb]uild/
[Ll]og/
[Ll]ogs/
 
# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates
 
# Visual Studio 2022 workspace
.vs/
.vscode/
 
# NuGet packages
*.nupkg
*.snupkg
# The packages folder can be restored via NuGet
**/[Pp]ackages/*
!**/[Pp]ackages/build/
!**/[Pp]ackages/repositories.config
 
# Azure build output
[Aa]pp_Data/
 
# Temporary and cache files
*.tmp
*.temp
*.bak
*.log
*.svclog
*.scc
 
# Rider / JetBrains
.idea/
*.iml
 
# Visual Studio Code
.history/
*.code-workspace
 
# Test results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.coverage
*.coveragexml
*.vsp
*.vspx
*.vspscc
*.psess
*.pidb
 
# Resharper
_ReSharper*/
*.DotSettings.user
 
# DotCover
.idea/
*.dotCover
 
# Visual Studio profiler
*.psess
*.vsp
*.vspx
 
# Tye
.tye/
 
# Node.js tools
node_modules/
 
# Others
*.exe